{
  "name": "prompt-management",
  "displayName": "Prompt Vault",
  "description": "Save and reuse prompts directly inside VS Code.",
  "version": "0.3.0",
  "publisher": "dhanvina",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhanvina/prompt-vault"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Snippets"
  ],
  "icon": "images/icon.png",
  "activationEvents": [
    "onView:promptVault.tree",
    "onView:promptVault.form"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "promptVault",
          "title": "Prompt Vault",
          "icon": "$(bookmark)"
        }
      ]
    },
    "views": {
      "promptVault": [
        {
          "id": "promptVault.tree",
          "name": "Prompts"
        },
        {
          "id": "promptVault.form",
          "name": "Editor",
          "type": "webview",
          "visibility": "hidden"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "promptVault.addPromptFromView",
          "when": "view == promptVault.tree",
          "group": "navigation@1"
        },
        {
          "command": "promptVault.searchPrompts",
          "when": "view == promptVault.tree",
          "group": "navigation@2"
        },
        {
          "command": "promptVault.clearSearch",
          "when": "view == promptVault.tree",
          "group": "navigation@3"
        },
        {
          "command": "promptVault.createChain",
          "when": "view == promptVault.tree",
          "group": "overflow@1"
        },
        {
          "command": "promptVault.importPrompts",
          "when": "view == promptVault.tree",
          "group": "overflow@2"
        },
        {
          "command": "promptVault.exportPrompts",
          "when": "view == promptVault.tree",
          "group": "overflow@3"
        }
      ],
      "view/item/context": [
        {
          "command": "promptVault.insertFromTree",
          "when": "view == promptVault.tree && viewItem == prompt",
          "group": "inline@1"
        },
        {
          "command": "promptVault.toggleFavorite",
          "when": "view == promptVault.tree && viewItem == prompt",
          "group": "inline@2"
        },
        {
          "command": "promptVault.editFromTree",
          "when": "view == promptVault.tree && viewItem == prompt",
          "group": "inline@3"
        },
        {
          "command": "promptVault.deleteFromTree",
          "when": "view == promptVault.tree && viewItem == prompt",
          "group": "inline@4"
        },
        {
          "command": "promptVault.previewPrompt",
          "when": "view == promptVault.tree && viewItem == prompt",
          "group": "context@1"
        },
        {
          "command": "promptVault.viewHistory",
          "when": "view == promptVault.tree && viewItem == prompt",
          "group": "context@2"
        },
        {
          "command": "promptVault.runChain",
          "when": "view == promptVault.tree && viewItem == chain",
          "group": "inline@1"
        },
        {
          "command": "promptVault.editChain",
          "when": "view == promptVault.tree && viewItem == chain",
          "group": "inline@2"
        },
        {
          "command": "promptVault.deleteChain",
          "when": "view == promptVault.tree && viewItem == chain",
          "group": "inline@3"
        }
      ]
    },
    "commands": [
      {
        "command": "promptVault.addPrompt",
        "title": "Prompt Vault: Add Prompt"
      },
      {
        "command": "promptVault.listPrompts",
        "title": "Prompt Vault: List Prompts"
      },
      {
        "command": "promptVault.editPrompt",
        "title": "Prompt Vault: Edit Prompt"
      },
      {
        "command": "promptVault.deletePrompt",
        "title": "Prompt Vault: Delete Prompt"
      },
      {
        "command": "promptVault.insertPrompt",
        "title": "Prompt Vault: Insert Prompt"
      },
      {
        "command": "promptVault.searchPrompts",
        "title": "Prompt Vault: Search Prompts",
        "icon": "$(search)"
      },
      {
        "command": "promptVault.clearSearch",
        "title": "Prompt Vault: Clear Search",
        "icon": "$(clear-all)"
      },
      {
        "command": "promptVault.importPrompts",
        "title": "Prompt Vault: Import Prompts",
        "icon": "$(cloud-download)"
      },
      {
        "command": "promptVault.exportPrompts",
        "title": "Prompt Vault: Export Prompts",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "promptVault.toggleFavorite",
        "title": "Toggle Favorite",
        "icon": "$(star)"
      },
      {
        "command": "promptVault.previewPrompt",
        "title": "Preview Prompt",
        "icon": "$(eye)"
      },
      {
        "command": "promptVault.viewHistory",
        "title": "View History",
        "icon": "$(history)"
      },
      {
        "command": "promptVault.createChain",
        "title": "Prompt Vault: Create Chain",
        "icon": "$(add)"
      },
      {
        "command": "promptVault.editChain",
        "title": "Edit Chain",
        "icon": "$(edit)"
      },
      {
        "command": "promptVault.deleteChain",
        "title": "Delete Chain",
        "icon": "$(trash)"
      },
      {
        "command": "promptVault.runChain",
        "title": "Run Chain",
        "icon": "$(run-all)"
      },
      {
        "command": "promptVault.insertFromTree",
        "title": "Insert",
        "icon": "$(run)"
      },
      {
        "command": "promptVault.editFromTree",
        "title": "Edit",
        "icon": "$(edit)"
      },
      {
        "command": "promptVault.deleteFromTree",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "promptVault.openAddForm",
        "title": "Add Prompt"
      },
      {
        "command": "promptVault.addPromptFromView",
        "title": "Add Prompt",
        "icon": "$(add)"
      }
    ],
    "keybindings": [
      {
        "command": "promptVault.insertPrompt",
        "key": "ctrl+alt+p",
        "mac": "cmd+alt+p",
        "when": "editorTextFocus"
      },
      {
        "command": "promptVault.searchPrompts",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "focusedView == promptVault.tree"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "22.x",
    "typescript": "^5.9.3"
  }
}
